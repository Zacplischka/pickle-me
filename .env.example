# Supabase project (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-side only (seed script, admin operations). Never expose client-side.
SUPABASE_SERVICE_ROLE_KEY=

# Google Places API — server-side key for the enrich script
GOOGLE_PLACES_API_KEY=
# Google Places API — browser key for place autocomplete and photos
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=

# Canonical site URL (used in metadata, sitemap and OG tags), e.g. https://mypickle.me
NEXT_PUBLIC_SITE_URL=

# Password for the /admin dashboard
ADMIN_PASSWORD=
